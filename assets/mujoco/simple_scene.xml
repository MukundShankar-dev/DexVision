<mujoco model="dexvision_simple_scene">
  <compiler angle="degree"/>

  <option timestep="0.01" gravity="0 0 -9.81"/>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.45 0.60 0.78" rgb2="0.05 0.07 0.10" width="512" height="512"/>
    <texture name="ground_grid" type="2d" builtin="checker" rgb1="0.18 0.22 0.24" rgb2="0.12 0.15 0.17" width="512" height="512"/>
    <material name="ground_grid" texture="ground_grid" texrepeat="6 6" reflectance="0.15"/>
    <material name="cube_orange" rgba="0.95 0.34 0.12 1"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="0 -3 3" dir="0 1 -1" diffuse="0.9 0.9 0.85"/>
    <geom name="ground" type="plane" size="3 3 0.05" material="ground_grid"/>

    <body name="cube" pos="0 0 0.35">
      <freejoint name="cube_freejoint"/>
      <geom name="cube_geom" type="box" size="0.15 0.15 0.15" mass="0.5" material="cube_orange"/>
    </body>

    <camera name="overview" pos="1.4 -1.6 1.0" euler="60 0 40"/>
  </worldbody>
</mujoco>
