<!--
  DexVision final hand scene.

  Final model: Shadow Hand E3M5, right hand, from Google DeepMind MuJoCo
  Menagerie. The vendored upstream files live in
  assets/mujoco/menagerie/shadow_hand/.

  The simple DexVision smoke-test hand remains at
  assets/mujoco/debug_hand_scene.xml and should not be used for Level 2/3 data.
-->
<mujoco model="dexvision_shadow_hand_scene">
  <include file="menagerie/shadow_hand/right_hand_dexvision.xml"/>

  <statistic extent="0.3" center="0.3 0 0"/>

  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <global azimuth="220" elevation="-30"/>
  </visual>

  <asset>
    <texture name="dexvision_skybox" type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture name="dexvision_groundplane" type="2d" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="dexvision_groundplane" texture="dexvision_groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="fill_light" pos="0 0 1"/>
    <light name="key_light" pos="0.3 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" pos="0 0 -0.1" size="0 0 0.05" type="plane" material="dexvision_groundplane"/>
    <camera name="overview" pos="0.55 -0.8 0.5" euler="1.15 0 0.58"/>
  </worldbody>
</mujoco>
